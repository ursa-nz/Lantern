#!/usr/bin/env bash
# Lantern launcher.
#
# @PYTHON@ is substituted by the installer to point at a python interpreter
# that has PyGObject available (apt's python3-gi).  We hardcode this so the
# app doesn't break for users who have a venv-shadowed `python3` on PATH.
#
# @SHAREDIR@ is the directory containing the `lantern/` Python package and
# the `node_modules/` directory with marp-cli.
set -e

export PYTHONPATH="@SHAREDIR@${PYTHONPATH:+:${PYTHONPATH}}"

# PDF export prints through WebKitGTK and PPTX goes through pandoc, so there's
# no bundled Chromium to point at — see lantern/export.py.

exec "@PYTHON@" -m lantern "$@"
